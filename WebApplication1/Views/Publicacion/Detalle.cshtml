@model Entidades.Publicacion
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Titulo;
    var esPropietario = User.FindFirstValue(ClaimTypes.NameIdentifier) == Model.UsuarioId.ToString();
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Volver al listado</a>
        </div>
    </div>

    <div class="row">
        <!-- Foto -->
        <div class="col-md-5">
            <div class="card shadow-sm">
                <img src="@Model.ImagenUrl" alt="@Model.Titulo" class="card-img-top" style="max-height: 400px; object-fit: cover;" />
            </div>
        </div>

        <!-- Info de la publicación -->
        <div class="col-md-7">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="badge bg-info text-dark">@Model.Categoria?.Nombre</span>
                        <span class="badge bg-secondary">@Model.Estado</span>
                    </div>

                    <h2 class="card-title mt-2">@Model.Titulo</h2>
                    <hr />

                    <h5>Descripción</h5>
                    <p class="card-text">@Model.Descripcion</p>

                    <div class="alert alert-warning mt-4 d-inline-block">
                        <strong>Cierra el:</strong> @Model.FechaCierre.ToString("dd/MM/yyyy")
                    </div>

                    <p class="mt-3 text-muted">
                        Publicado por: <strong>@Model.Usuario?.Nombre @Model.Usuario?.Apellido</strong>
                    </p>

                    @if (esPropietario)
                    {
                        <div class="mt-4">
                            <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-primary">Editar publicación</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <hr class="my-5" />

    <!-- Chat -->
    <div class="row">
        <div class="col-12">
            <h4>Chat de la subasta</h4>
            <div class="card mt-2">
                <div id="chat-container" class="card-body bg-light" style="min-height: 300px;">
                    <p class="text-muted text-center mt-5">Acá va a ir el chat xd</p>
                </div>
            </div>
        </div>
    </div>
</div>