@model Entidades.Publicacion
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Titulo;
    var esPropietario = User.FindFirstValue(ClaimTypes.NameIdentifier) == Model.UsuarioId.ToString();
}

<div class="row">
    <div class="col-md-6">
        <img src="@Model.ImagenUrl" alt="@Model.Titulo" class="img-fluid rounded" />
    </div>

    <div class="col-md-6">
        <h1>@Model.Titulo</h1>

        <p class="text-muted mb-1">Categoría: @Model.Categoria?.Nombre</p>
        <span class="badge bg-secondary">@Model.Estado</span>

        <p class="mt-3">@Model.Descripcion</p>

        <p>
            <strong>Cierra el:</strong> @Model.FechaCierre.ToString("dd/MM/yyyy")
        </p>

        <p class="text-muted">
            Publicado por: @Model.Usuario?.Nombre @Model.Usuario?.Apellido
        </p>

        <div class="d-flex gap-2 mt-3">
            @if (esPropietario)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Editar publicación</a>
            }
            <a asp-action="Index" class="btn btn-secondary">Volver</a>
        </div>
    </div>
</div>

<hr class="my-4" />

<div class="row">
    <div class="col-12">
        <h3>Chat</h3>
        <div id="chat-container" class="border rounded p-3" style="min-height: 300px;">
            <p class="text-muted mb-0">aca iria el chat xd</p>
        </div>
    </div>
</div>