@model Entidades.Publicacion
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Titulo;
    var esPropietario = User.FindFirstValue(ClaimTypes.NameIdentifier) == Model.UsuarioId.ToString();
}

<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Volver al listado
            </a>
        </div>
    </div>

    <div class="row">

        <!-- Imagen -->
        <div class="col-lg-5 mb-4">

            <div class="card shadow-sm border-0">

                <img src="@Model.ImagenUrl"
                     class="card-img-top"
                     alt="@Model.Titulo"
                     style="height:420px;object-fit:cover;" />

            </div>

        </div>

        <!-- Información -->
        <div class="col-lg-7">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <span class="badge bg-primary">
                            @Model.Categoria?.Nombre
                        </span>

                        <span class="badge bg-secondary">
                            @Model.Estado
                        </span>

                    </div>

                    <h2 class="mt-3 fw-bold">
                        @Model.Titulo
                    </h2>

                    <hr />

                    <h5>Descripción</h5>

                    <p class="text-muted">
                        @Model.Descripcion
                    </p>

                    <div class="alert alert-warning mt-4">

                        <strong>

                            <i class="bi bi-clock"></i>

                            Cierra el:

                        </strong>

                        @Model.FechaCierre.ToString("dd/MM/yyyy")

                    </div>

                    <div class="mt-4">

                        <h6 class="text-muted">

                            Publicado por

                        </h6>

                        <h5>

                            <i class="bi bi-person-circle"></i>

                            @Model.Usuario?.Nombre @Model.Usuario?.Apellido

                        </h5>

                    </div>

                    <hr />

                    @if (esPropietario)
                    {
                        <div class="d-grid">

                            <a asp-action="Editar"
                                   asp-route-id="@Model.Id"
                                   class="btn btn-primary">

                                <i class="bi bi-pencil-square"></i>

                                Editar publicación

                            </a>

                        </div>
                    }
                    else
                    {
                        <div class="d-grid gap-2">

                            <a asp-controller="Chat"
                                   asp-action="CrearConversacion"
                                   asp-route-publicacionId="@Model.Id"
                                   class="btn btn-success btn-lg">

                                <i class="bi bi-chat-dots"></i>

                                Contactar vendedor

                            </a>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

    <div class="row mt-5">

        <div class="col-12">

            <div class="card border-0 shadow-sm">

                <div class="card-header bg-white">

                    <h4 class="mb-0">

                        <i class="bi bi-info-circle"></i>

                        Información de la publicación

                    </h4>

                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-4">

                            <strong>Estado</strong>

                            <p>@Model.Estado</p>

                        </div>

                        <div class="col-md-4">

                            <strong>Categoría</strong>

                            <p>@Model.Categoria?.Nombre</p>

                        </div>

                        <div class="col-md-4">

                            <strong>Fecha de cierre</strong>

                            <p>@Model.FechaCierre.ToString("dd/MM/yyyy")</p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>