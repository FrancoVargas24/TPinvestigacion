@using System.Security.Claims
@using System.Collections.Generic
@using System.Text.Json

@model Entidades.Conversacion

@{
    ViewData["Title"] = "Chat";

    var usuarioLogueado = int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)!.Value);
    var coloresUsuario = new Dictionary<string, string>();
    var paleta = new[] { "#6f42c1", "#fd7e14", "#20c997", "#dc3545", "#0dcaf0", "#198754", "#d63384", "#0d6efd", "#6610f2", "#e83e8c" };
    var idxColor = 0;
    foreach (var m in Model.Mensajes.OrderBy(m => m.FechaEnvio))
    {
        var key = m.UsuarioId.ToString();
        if (m.UsuarioId != usuarioLogueado && !coloresUsuario.ContainsKey(key))
        {
            coloresUsuario[key] = paleta[idxColor % paleta.Length];
            idxColor++;
        }
    }
    var coloresJson = JsonSerializer.Serialize(coloresUsuario);
}

<section class="hero-section text-white text-center d-flex align-items-center justify-content-center">

    <div class="hero-overlay"></div>

    <div class="container position-relative py-5">

        <i class="bi bi-chat-heart display-1 mb-3"></i>

        <h1 class="display-5 fw-bold">

            @Model.Publicacion.Titulo

        </h1>

        <p class="lead">
            @if (Model.VendedorId == usuarioLogueado)
            {
                <span>Conversación con <strong>@Model.Comprador?.Nombre @Model.Comprador?.Apellido</strong> (comprador)</span>
            }
            else
            {
                <span>Conversación con <strong>@Model.Vendedor?.Nombre @Model.Vendedor?.Apellido</strong> (vendedor)</span>
            }
        </p>

    </div>

</section>

<section class="container py-5">

    <div class="card shadow">

        <div class="card-header d-flex justify-content-between align-items-center">

            <h5 class="mb-0">
                <i class="bi bi-person-circle"></i> Chat
                @if (Model.Cerrada)
                {
                    <span class="badge bg-secondary ms-2">Cerrada</span>
                }
            </h5>

            @if (Model.VendedorId == usuarioLogueado && !Model.Cerrada)
            {
                <form asp-action="Cerrar" method="post" onsubmit="return confirm('¿Cerrar esta conversación?');">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-lock"></i> Cerrar chat
                    </button>
                </form>
            }

        </div>

        <div class="card-body" id="chatMessages" style="height:450px;overflow-y:auto;"
             data-conversacion-id="@Model.Id"
             data-usuario-logado="@usuarioLogueado"
             data-colores="@Html.Raw(coloresJson)">

            @foreach (var mensaje in Model.Mensajes.OrderBy(m => m.FechaEnvio))
            {
                if (mensaje.UsuarioId == usuarioLogueado)
                {
                    <div class="d-flex justify-content-end mb-3 mensaje-item" data-usuario="@mensaje.UsuarioId" data-conversacion="@mensaje.ConversacionId">

                        <div class="bg-primary text-white rounded p-3">

                            <strong>Vos</strong>

                            <br />

                            @mensaje.Texto

                            <br />

                            <small>

                                @mensaje.FechaEnvio.ToString("dd/MM HH:mm")

                            </small>

                        </div>

                    </div>
                }
                else
                {
                    var color = coloresUsuario.GetValueOrDefault(mensaje.UsuarioId.ToString(), "#6c757d");
                    <div class="d-flex justify-content-start mb-3 mensaje-item" data-usuario="@mensaje.UsuarioId" data-conversacion="@mensaje.ConversacionId">

                        <div class="rounded p-3 text-white" style="background-color:@color;">

                            <strong>

                                @mensaje.Usuario.Nombre

                            </strong>

                            <br />

                            @mensaje.Texto

                            <br />

                            <small class="text-white-50">

                                @mensaje.FechaEnvio.ToString("dd/MM HH:mm")

                            </small>

                        </div>

                    </div>
                }
            }

        </div>

        <div class="card-footer">

            @if (Model.Cerrada)
            {
                <p class="text-muted text-center mb-0 py-2">
                    <i class="bi bi-lock"></i> Esta conversación está cerrada.
                </p>
            }
            else
            {
                <div class="input-group">

                    <input type="text" id="chatInput" class="form-control" placeholder="Escribí un mensaje..." maxlength="1000" autocomplete="off" />

                    <button class="btn btn-primary" id="btnEnviarChat">

                        <i class="bi bi-send"></i> Enviar

                    </button>

                </div>
            }

        </div>

    </div>

</section>

@section Scripts {
    <script src="~/js/chat.js" asp-append-version="true"></script>
}